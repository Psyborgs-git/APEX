import type { QuoteDto, OrderDto, PositionDto, NewOrderRequestDto, RiskStatusDto } from './types';

const IS_TAURI = typeof window !== 'undefined' && '__TAURI__' in window;

let mockPositions: PositionDto[] = [];
let mockOrders: OrderDto[] = [];

